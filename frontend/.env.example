# ---- Frontend environment variables (Vite) ----
# Copy to `.env` and adjust as needed. All client-exposed vars MUST be prefixed with VITE_.

# Base URL for the API. Leave as the default to use the Vite dev proxy (recommended for local dev,
# keeps the httpOnly refresh cookie first-party). In production set the full API origin, e.g.
# VITE_API_URL=https://api.yourdomain.com/api/v1
VITE_API_URL=/api/v1

# Stripe publishable (test) key — only needed if you render Stripe Elements on the client.
# The Checkout redirect flow used here does not require it, but it is wired for future use.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
