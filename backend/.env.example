# ---- Backend configuration ----
# ASP.NET Core reads configuration from appsettings.json + appsettings.{Environment}.json,
# and ENVIRONMENT VARIABLES override those. Nested keys use a double underscore "__".
#
# For local development the committed appsettings.Development.json already contains working
# defaults (LocalDB/SQL Server via Windows auth + a dev JWT secret), so the app runs with no
# extra setup. Use the variables below to override for production or to enable Stripe.
#
# On Windows PowerShell you can set these for a session, e.g.:
#   $env:Stripe__SecretKey = "sk_test_xxx"
# Or use `dotnet user-secrets` for local secrets.

# Database — SQL Server connection string (integer-cents money handling; EF Core code-first)
ConnectionStrings__Default=Server=localhost;Database=EcommerceDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true
# Example with SQL auth / Docker container:
# ConnectionStrings__Default=Server=localhost,1433;Database=EcommerceDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True

# JWT — MUST be a long random secret in production (>= 32 bytes)
Jwt__Issuer=Ecommerce.API
Jwt__Audience=Ecommerce.Client
Jwt__Secret=change-me-to-a-long-random-secret-of-at-least-32-bytes
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# Stripe (test mode) — get keys at https://dashboard.stripe.com/test/apikeys
Stripe__SecretKey=sk_test_xxx
Stripe__PublishableKey=pk_test_xxx
# From `stripe listen --forward-to http://localhost:5065/api/v1/webhooks/stripe`
Stripe__WebhookSecret=whsec_xxx
Stripe__Currency=usd

# Frontend origin — used for CORS and Stripe success/cancel redirect URLs
Frontend__BaseUrl=http://localhost:5173

# Uploads
Storage__UploadsFolder=uploads
Storage__MaxFileSizeBytes=5242880
